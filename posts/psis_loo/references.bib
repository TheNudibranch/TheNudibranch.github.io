 journal = {The Annals of Probability},
 number = {5},
 pages = {792--804},
 publisher = {Institute of Mathematical Statistics},
 title = {Residual Life Time at Great Age},
 urldate = {2025-02-22},
 volume = {2},
 year = {1974}
}

